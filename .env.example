# ──────────────────────────────────────────────
# Database (Supabase / PostgreSQL)
# ──────────────────────────────────────────────
# Connection pooler URL (used by Prisma at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Direct connection URL (used by Prisma for migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ──────────────────────────────────────────────
# NextAuth.js
# ──────────────────────────────────────────────
# Public URL of your app (change to production URL when deploying)
NEXTAUTH_URL="http://localhost:3000"

# A random secret used to sign JWT tokens — generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-random-string-here"

# ──────────────────────────────────────────────
# Cloudinary (image uploads)
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ──────────────────────────────────────────────
# SMTP (email notifications via Nodemailer)
# ──────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-email@gmail.com"
# App Password (not your regular Gmail password)
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="FindIT Campus <your-email@gmail.com>"
